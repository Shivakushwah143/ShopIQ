# ===========================================
# SHOPIQ - Complete .gitignore
# ===========================================

# ===========================================
# DEPENDENCIES
# ===========================================
## Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

## Package manager locks (include if you want, but usually better to commit)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ===========================================
# ENVIRONMENT VARIABLES
# ===========================================
## Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.staging.local

## API keys and secrets
*.key
*.pem
*.p12
*.pfx
secrets/
credentials.json
service-account.json

# ===========================================
# RUNTIME DATA
# ===========================================
## Logs
logs/
*.log
*.log.*

## Database
*.db
*.sqlite
*.sqlite3
*.db-journal
mongodb-data/
postgres-data/

## Uploads
uploads/
public/uploads/
temp/
tmp/
*.tmp

## Qdrant data (if running locally)
qdrant_storage/
qdrant-data/
storage/

## PID files
*.pid
*.seed
*.pid.lock

# ===========================================
# BUILD OUTPUTS
# ===========================================
## Compiled files
dist/
build/
out/
*.js.map
*.ts.map
*.js
!app.js  # Keep app.js since it's our main file
!*.config.js  # Keep config files

## TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo

## Webpack
assets/webpack/
stats.json

## Next.js
.next/
out/

## Nuxt
.nuxt/
dist/

# ===========================================
# TESTING
# ===========================================
## Coverage reports
coverage/
.nyc_output/
coverage.json
*.lcov

## Testing outputs
test-results/
junit.xml
test.log

## Cypress
cypress/videos/
cypress/screenshots/
cypress/downloads/

## Playwright
test-results/
playwright-report/
playwright/.cache/

# ===========================================
# IDE AND EDITOR FILES
# ===========================================
## VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/

## IntelliJ / WebStorm
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/
atlassian-ide-plugin.xml

## VS Code (alternative)
.vscode-test/
.vscode-test

## Sublime Text
*.sublime-project
*.sublime-workspace
.sublime-gulp.cache

## Vim
*.swp
*.swo
*~
.DS_Store
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

## Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

## Eclipse
.project
.classpath
.settings/
*.prefs
*.pydevproject

## NetBeans
nbproject/private/
nbbuild/
dist/
nbdist/
nbactions.xml
nb-configuration.xml
.nb-gradle/

# ===========================================
# OS GENERATED FILES
# ===========================================
## macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
.DocumentRevisions-V100
*.icloud

## Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

## Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ===========================================
# CACHE FILES
# ===========================================
## npm/yarn cache
.npm/
.yarn/
.yarn-cache/
.yarn-integrity
.yarn-offline-mirror/

## ESLint
.eslintcache

## Stylelint
.stylelintcache

## Prettier
.prettiercache

## Parcel
.parcel-cache/

## Turbopack
.turbo/

## Vite
.vite-opt-cache/

# ===========================================
# TEMPLATES AND DOCS
# ===========================================
## Project docs (usually committed separately)
/docs/_build/
/docs/_site/
/site/

## MkDocs
/site/

## VuePress
.vuepress/dist/
.vuepress/cache/

## Docusaurus
.docusaurus/
build/

# ===========================================
# DOCKER
# ===========================================
*.tar
*.tar.gz
docker/data/
docker/db-data/
.dockerignore
docker-compose.override.yml

# ===========================================
# SECURITY
# ===========================================
## SSL certificates
*.crt
*.cert
*.csr
*.key
*.pem
ssl/
certs/

## SSH keys
*.pem
*.ppk
id_*
*.pub

## GPG keys
*.gpg
*.asc

# ===========================================
# BACKUP FILES
# ===========================================
*.bak
*.backup
*.old
*.orig
*.tmp
*.temp
*.swp
*.swo
*~

# ===========================================
# PROJECT SPECIFIC
# ===========================================
## ShopIQ specific
/data/
/mongodata/
/qdrant-data/
/product-images/
/user-uploads/
*.session
*.token

## Don't ignore these important files
!README.md